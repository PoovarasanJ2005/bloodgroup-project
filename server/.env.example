# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/bloodgroup_db?retryWrites=true&w=majority

# ── CORS Origins (comma-separated, add your production frontend URL) ─────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=<your-secret-key>
JWT_EXPIRE=7d

# ── AES Encryption (fingerprint images) ──────────────────────────────────────
AES_SECRET_KEY=<your-aes-key>

# ── Flask ML API ───────────────────────────────────────────────────────────────
ML_API_URL=http://localhost:5000

# ── Email (optional) ─────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# ── Admin seed credentials ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@bloodgroup.com
ADMIN_PASSWORD=<your-admin-password>
